else
  export NODE_PATH="/home/wsluser/MoveEase/node_modules/.pnpm/eslint-config-prettier@10.1.8_eslint@9.39.5_jiti@2.7.0_/node_modules/eslint-config-prettier/node_modules:/home/wsluser/MoveEase/node_modules/.pnpm/eslint-config-prettier@10.1.8_eslint@9.39.5_jiti@2.7.0_/node_modules:/home/wsluser/MoveEase/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../eslint-config-prettier/bin/cli.js" "$@"
else
  exec node  "$basedir/../eslint-config-prettier/bin/cli.js" "$@"
fi
